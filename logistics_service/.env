# Copy to .env for local dev. In staging/production these are injected from
# OCI Vault by the deploy pipeline -- never commit real secrets here.

LOGISTICS_ENVIRONMENT=development
LOGISTICS_ENFORCE_HTTPS=false

LOGISTICS_DATABASE_URL=postgresql+asyncpg://postgres:kanni3750@localhost:5432/nutmeals_db
LOGISTICS_REDIS_URL=redis://localhost:6379/0
LOGISTICS_CELERY_BROKER_URL=redis://localhost:6379/1
LOGISTICS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

LOGISTICS_DELHIVERY_API_BASE=https://staging-express.delhivery.com
LOGISTICS_DELHIVERY_API_TOKEN=changeme
LOGISTICS_INDIA_POST_API_BASE=https://api.indiapost.gov.in
LOGISTICS_INDIA_POST_API_KEY=changeme

LOGISTICS_ORDERS_SERVICE_URL=http://orders-service:8000
LOGISTICS_INVENTORY_SERVICE_URL=http://inventory-service:8000
LOGISTICS_MESSAGING_SERVICE_URL=http://messaging-service:8000

LOGISTICS_JWT_PUBLIC_KEY=
LOGISTICS_JWT_ALGORITHM=RS256
