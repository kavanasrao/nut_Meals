# Copy to .env and fill in real values. In staging/production these are
# injected by OCI Vault at deploy time, not committed to source control.

SECURITY_ENV=local
SECURITY_DATABASE_URL=postgresql+asyncpg://nutmeals:nutmeals@security-db:5432/security_db
SECURITY_REDIS_URL=redis://security-redis:6379/0
SECURITY_CELERY_BROKER_URL=redis://security-redis:6379/1
SECURITY_CELERY_RESULT_BACKEND=redis://security-redis:6379/2
SECURITY_JWT_SECRET=change-me-in-vault
SECURITY_JWT_ALGORITHM=HS256
SECURITY_AUTH_SERVICE_URL=http://auth-service:8000
SECURITY_WAF_ENABLED=true
SECURITY_WAF_BLOCK_MODE=true
SECURITY_ENFORCE_HTTPS=false
SECURITY_ALLOWED_ORIGINS=["http://localhost:3000"]
SECURITY_OCI_VAULT_ENABLED=false
