# Copy to .env for local development. NEVER commit real secrets here —
# production values are injected via OCI Vault at deploy/runtime.
SEO_ENV=development
SEO_HTTPS_ONLY=false
SEO_DATABASE_URL=postgresql+asyncpg://seo_user:seo_pass@localhost:5433/seo_service_db
SEO_REDIS_URL=redis://localhost:6380/0
SEO_CELERY_BROKER_URL=redis://localhost:6380/1
SEO_CELERY_RESULT_BACKEND=redis://localhost:6380/2
SEO_CATALOG_SERVICE_URL=http://localhost:8001
SEO_REVIEWS_SERVICE_URL=http://localhost:8002
SEO_BLOG_SERVICE_URL=http://localhost:8003
SEO_PUBLIC_BASE_URL=http://localhost:8004
SEO_JWT_PUBLIC_KEY=dev-only-placeholder-do-not-use-in-prod
