# Admin Service — environment variables
# Copy to .env and fill in real values.

SERVICE_NAME=admin-service
ENVIRONMENT=local
DEBUG=true

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:kanni3750@postgres:5432/nutmeals_db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT (use a long, random string in production) ───────────────────────────
JWT_SECRET=change_me_admin_super_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Downstream service URLs ──────────────────────────────────────────────────
USER_SERVICE_URL=http://user-service:8005
ORDER_SERVICE_URL=http://order-service:8001
PAYMENT_SERVICE_URL=http://payment-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003
DELIVERY_SERVICE_URL=http://delivery-service:8004
MEAL_SERVICE_URL=http://meal-service:8006

# ── Internal token for service-to-service calls ──────────────────────────────
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# ── HTTP timeout for downstream calls (seconds) ──────────────────────────────
DOWNSTREAM_TIMEOUT=15.0
