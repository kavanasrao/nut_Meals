# Copy to .env for local, non-Docker development.
# Production values are injected from OCI Vault by the deploy pipeline —
# never commit real secrets to this file or to source control.

CATALOG_DATABASE_URL=postgresql+asyncpg://catalog:catalog@localhost:5432/catalog_db
CATALOG_REDIS_URL=redis://localhost:6379/0
CATALOG_CELERY_BROKER_URL=redis://localhost:6379/1
CATALOG_CELERY_RESULT_BACKEND=redis://localhost:6379/2
CATALOG_ENVIRONMENT=local
CATALOG_DEBUG=true
CATALOG_FORCE_HTTPS=false
CATALOG_JWT_SECRET_KEY=change-me-local-only
CATALOG_INVENTORY_SERVICE_URL=http://localhost:8001
CATALOG_OCI_VAULT_OCID=
