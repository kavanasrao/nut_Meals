# ──────────────────────────────────────────────────────────────────────────────
# nut_Meals Infra Service — Environment Variables
# Copy to .env and fill in production values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_VERSION=1.0.0
SECRET_KEY=<generate: openssl rand -hex 32>
INTERNAL_API_KEY=<generate: openssl rand -hex 24>
ALLOWED_HOSTS=infra.internal.nut-meals.com
ALLOWED_ORIGINS=https://admin.nut-meals.com

# ── Database (this service) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://infra:<password>@postgres:5432/infra_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@redis:6379/3
CELERY_BROKER_URL=redis://:password@redis:6379/3
CELERY_RESULT_BACKEND=redis://:password@redis:6379/3

# ── Backup targets (comma-separated alias=DSN pairs) ─────────────────────────
BACKUP_DB_TARGETS=orders=postgresql://orders:<pw>@postgres:5432/orders_db,users=postgresql://users:<pw>@postgres:5432/users_db,meals=postgresql://meals:<pw>@postgres:5432/meals_db

# ── Object Storage ────────────────────────────────────────────────────────────
# AWS S3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=<aws-access-key>
S3_SECRET_ACCESS_KEY=<aws-secret-key>
S3_BUCKET_NAME=nut-meals-backups-prod
S3_REGION=us-east-1
S3_PATH_PREFIX=backups

# OCI Object Storage (uncomment and set endpoint if using OCI)
# S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# S3_ACCESS_KEY_ID=<oci-access-key>
# S3_SECRET_ACCESS_KEY=<oci-secret-key>
# S3_REGION=us-ashburn-1

# ── Backup encryption ─────────────────────────────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=<fernet-key>
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_CRON=0 2 * * *

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_EMAIL=ops@nut-meals.com
