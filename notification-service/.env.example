ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://notify:notify@notification-db:5432/notification_service
SYNC_DATABASE_URL=postgresql+psycopg2://notify:notify@notification-db:5432/notification_service
REDIS_URL=redis://notification-redis:6379/0
CELERY_BROKER_URL=redis://notification-redis:6379/1
CELERY_RESULT_BACKEND=redis://notification-redis:6379/2

JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# Secrets below are placeholders resolved from OCI Vault at startup in prod
OCI_VAULT_ID=
OCI_VAULT_SECRET_SMTP=
OCI_VAULT_SECRET_TWILIO=
OCI_VAULT_SECRET_WHATSAPP=

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=changeme
SMTP_FROM=notifications@nutmeals.com

TWILIO_ACCOUNT_SID=changeme
TWILIO_AUTH_TOKEN=changeme
TWILIO_FROM_NUMBER=+10000000000

WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_TOKEN=changeme
WHATSAPP_PHONE_ID=changeme

FORCE_HTTPS=true
