# Notification Service — environment variables

SERVICE_NAME=notification-service
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=postgresql://postgres:kanni3750@postgres:5432/nutmeals_db
REDIS_URL=redis://redis:6379/0

# ── WhatsApp provider ──────────────────────────────────────────────────────
# Options: twilio | meta
WHATSAPP_PROVIDER=twilio

# ── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Meta WhatsApp Business API (leave blank if not using) ──────────────────
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# ── Retry policy ───────────────────────────────────────────────────────────
# Seconds between retry attempts (comma-separated)
NOTIFICATION_RETRY_DELAYS=30,120,600
NOTIFICATION_MAX_RETRIES=3

# ── Redis channels to subscribe ────────────────────────────────────────────
SUBSCRIBED_CHANNELS=ORDER_CREATED,PAYMENT_SUCCESS,DELIVERY_ASSIGNED
