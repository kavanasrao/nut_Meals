# Copy to .env for local development. In staging/production these values
# are injected from OCI Vault by the deployment pipeline, never committed.
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cart_checkout_ext
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/cart_checkout_ext
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JWT_SECRET_KEY=local-dev-secret-do-not-use-in-prod
PAYMENTS_SERVICE_URL=http://payments-service.internal:8000
NOTIFICATIONS_SERVICE_URL=http://notifications-service.internal:8000
CUSTOMER_PROFILE_SERVICE_URL=http://customer-profile-service.internal:8000
ENFORCE_HTTPS=false
