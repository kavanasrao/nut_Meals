# API Gateway — environment variables

SERVICE_NAME=api-gateway
ENVIRONMENT=local
DEBUG=true

REDIS_URL=redis://redis:6379/0

# Shared JWT secret (must match all downstream services)
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256

# ── Downstream service URLs ────────────────────────────────────────────────
ORDER_SERVICE_URL=http://order-service:8001
PAYMENT_SERVICE_URL=http://payment-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003
DELIVERY_SERVICE_URL=http://delivery-service:8004
USER_SERVICE_URL=http://user-service:8005
MEAL_SERVICE_URL=http://meal-service:8006

# ── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins or "*" for development
CORS_ORIGINS=*
