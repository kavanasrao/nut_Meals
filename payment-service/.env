# Payment Service — environment variables

SERVICE_NAME=payment-service
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:kanni3750@localhost:5432/nutmeals_db
REDIS_URL=redis://redis:6379/0

JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256

# ── Provider selection ─────────────────────────────────────────────────────
# Options: juspay | stripe | razorpay
PAYMENT_PROVIDER=juspay

# ── Juspay ─────────────────────────────────────────────────────────────────
JUSPAY_API_KEY=your_juspay_api_key
JUSPAY_MERCHANT_ID=your_merchant_id
JUSPAY_BASE_URL=https://sandbox.juspay.in
JUSPAY_WEBHOOK_SECRET=your_juspay_webhook_secret

# ── Stripe (leave blank if not using) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Razorpay (leave blank if not using) ───────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
